# ElevenLabs voiceover for the Executive Briefing (Presentation Mode).
# Copy to app/.env (gitignored) for local `vite` dev, and set the same vars in
# the Vercel project → Settings → Environment Variables for the deployed site.
# The key is ONLY read server-side (the /api/tts function and the Vite dev shim);
# it is never exposed in the client bundle.

ELEVENLABS_API_KEY=
# Any voice from your ElevenLabs account (this is the briefing's default).
ELEVENLABS_VOICE_ID=D3VCLJOhFBmI8f7VjA5S
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
